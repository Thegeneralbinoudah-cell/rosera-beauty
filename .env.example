# خيار 1: ضعي الملف هنا: rosera/.env أو rosera/.env.local
# خيار 2: ضعي المفاتيح في المجلد الأعلى ROSERA/.env.local (سيُحمَّل تلقائياً)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
# Moyasar (بوابة الدفع)
VITE_MOYASAR_PUBLISHABLE_KEY=pk_test_xxxxx
VITE_PAYMENT_MODE=free

# روزي (Edge Function rozi-chat) — تُضاف في Supabase Dashboard → Edge Functions → Secrets
# وليس في Vite (لا تُعرَّض للمتصفح)
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...   (احتياطي إذا فشل OpenAI)
