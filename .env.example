# خيار 1: rosera/.env أو rosera/.env.local (بجانب package.json)
# خيار 2: ROSERA/.env.local في المجلد الأعلى — يُدمج مع rosera/ (الأولوية لـ rosera)
# بعد أي تعديل: أوقفي وأعدي تشغيل npm run dev
# المشروع الحالي (Edge): https://ntboqussygvnbbqspwjq.supabase.co/functions/v1/rozi-chat
VITE_SUPABASE_URL=https://ntboqussygvnbbqspwjq.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
# OAuth (Google / Apple)
# ——— في Supabase Dashboard ———
#   Authentication → URL configuration:
#     Site URL = نطاقك (مثلاً https://app.example.com أو http://localhost:5173 للتطوير)
#     Redirect URLs = يجب أن يشمل تطبيقك: http://localhost:5173/auth/callback و …/auth/callback للإنتاج
#   Authentication → Providers: فعّلي Google و Apple (Client ID / Secret من المطوّرين).
# ——— خطأ redirect_uri_mismatch (Google / Apple) ———
#   المزوّد يتطلب رابط **Supabase** وليس رابط التطبيق فقط. أضفّي بالضبط (استبدلي PROJECT بـ VITE_SUPABASE_URL):
#     https://<PROJECT_REF>.supabase.co/auth/v1/callback
#   Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
#     → Authorized redirect URIs → أضفّي الرابط أعلاه.
#   Apple Developer → Identifiers → Services ID (Sign in with Apple) → Configure
#     → Return URLs → أضفّي نفس الرابط أعلاه.
# اختياري: إذا كان عنوان التطبيق الفعلي يختلف عن window.location.origin (نشر/بروكسي):
# VITE_AUTH_REDIRECT_URL=https://your-domain.com/auth/callback
# الخرائط: Google Maps فقط (مفتاح VITE_GOOGLE_MAPS_API_KEY أو المضمّن في googleMapsApiKey.ts)
# اختياري: Map ID للخرائط المتّجهة و Advanced Markers (لوحة Google → Map Management)
# VITE_GOOGLE_MAPS_MAP_ID=xxxxxxxxxxxxxxxx
# Moyasar (بوابة الدفع) — للإنتاج استخدمي pk_live_… من لوحة Moyasar
VITE_MOYASAR_PUBLISHABLE_KEY=pk_live_xxxxx
# Stripe — إن وُضعت، صفحة «اشتراك الصالون» تستخدم Stripe (بطاقة + Apple Pay) بدل Moyasar
# أنشئي في Stripe لوحة تحكم: منتجات شهرية SAR بأسعار 199 / 399 / 799 ر.س كما في التطبيق
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_…
# اختياري: الاسم الظاهر في Apple Pay (الافتراضي: Beauty Hub Saudi)
# VITE_MOYASAR_APPLE_PAY_LABEL=Rosera
# live = Moyasar (pk_live_) | free = بدون بوابة دفع
# عند npm run build يُفترض live تلقائياً إن لم تُعرّفي المتغير — للتطوير عرّفيها صراحةً في .env.local
VITE_PAYMENT_MODE=live

# Google Maps (Map page): Maps JavaScript API + Places API (New) — restrict key by HTTP referrer in Cloud Console
# ضعي المفتاح الحقيقي بعد = — إما باسم VITE_ أو بدون (يُنسَخ للعميل تلقائياً من vite.config)
# VITE_GOOGLE_MAPS_API_KEY=AIzaSy...
# أو:
# GOOGLE_MAPS_API_KEY=AIzaSy...

# PostHog — تحليلات السلوك (اختياري). بدون المفتاح لا يُحمَّل التتبع.
# https://app.posthog.com → Project → Project API key
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs — صوت روزي (TTS) **إلزامي** للصوت: صوت سعودي أنثوي مستنسخ فقط (لا Web Speech)
# VITE_ELEVENLABS_API_KEY=
# معرّف الصوت المستنسخ من ElevenLabs (إلزامي — بدون fallback)
# VITE_ELEVENLABS_VOICE_ID=

# روزي (Edge Function rozi-chat) — تُضاف في Supabase → Edge Functions → Secrets
# وليس في Vite. النموذج ثابت في الدالة: gpt-4o (OpenAI).
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# ——— Supabase Edge Secrets (لوحة Supabase → Edge Functions → Secrets) ———
# MOYASAR_SECRET_KEY=…  (موجود لـ verify-payment)
#
# Stripe (اشتراك الصالونات — Edge Functions: create-subscription, stripe-webhook, stripe-sync-salon-subscription, stripe-update-salon-auto-renew)
# STRIPE_SECRET_KEY=sk_live_…
# STRIPE_WEBHOOK_SECRET=whsec_…   ← من Stripe Dashboard → Webhooks → endpoint …/functions/v1/stripe-webhook
# STRIPE_PRICE_ID_BASIC=price_…
# STRIPE_PRICE_ID_PRO=price_…
# STRIPE_PRICE_ID_PREMIUM=price_…
# تجديد اشتراك الصالونات اليومي: استدعِ POST …/functions/v1/renew-salon-subscriptions
# مع الهيدر: x-cron-secret: <نفس القيمة>
# RENEWAL_CRON_SECRET=طويلة_عشوائية
# SITE_URL=https://your-app.com  (callback_url لـ Moyasar عند التجديد)
