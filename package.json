{
  "name": "rosera",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "sh -c 'for p in 5173 5174 5175; do lsof -ti tcp:$p 2>/dev/null | xargs kill -9 2>/dev/null; done; exec vite'",
    "build": "tsc -b && vite build",
    "build:analyze": "tsc -b && ANALYZE=true vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:build": "npm run build && npx cap sync",
    "cap:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "cap:android": "npm run build && npx cap sync android && npx cap open android",
    "seed:sql": "node scripts/generate-rosera-full-seed.mjs",
    "seed:master": "node scripts/generate-master-seed.mjs",
    "seed:eastern50": "node scripts/generate-eastern-khobar-dammam-50.mjs",
